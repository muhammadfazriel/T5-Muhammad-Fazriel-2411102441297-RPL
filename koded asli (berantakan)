#include <iostream>
using namespace std;

// Fungsi hitung
void htg(double a, int b) {
    double t = a * b;
    double p = t * 0.1; // Pajak 10 persen
    double total = t + p;

    cout << "Item dihitung..." << endl;
    cout << "Harga: " << a << endl;
    cout << "Qty: " << b << endl;
    cout << "Total: " << total << endl;
}

double itngPajak(double n) {
    return n * 0.1;
}

int main() {
    htg(15000, 3);
    return 0;
}
