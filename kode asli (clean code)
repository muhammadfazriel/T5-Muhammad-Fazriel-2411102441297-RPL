# Gunakan konstanta agar mudah diubah di satu tempat
TAX_RATE = 0.1

def calculate_tax(amount):
    """Menghitung nilai pajak berdasarkan nominal."""
    return amount * TAX_RATE

def calculate_total_price(price, quantity):
    """Logika hanya untuk menghitung total harga (SRP)."""
    subtotal = price * quantity
    return subtotal + calculate_tax(subtotal)

def display_invoice(price, quantity, total):
    """Fungsi khusus untuk menampilkan output ke layar (SRP)."""
    print("=== STRUK PEMBAYARAN ===")
    print(f"Harga Satuan : Rp{price}")
    print(f"Jumlah Barang: {quantity}")
    print(f"Total Akhir  : Rp{total}")
    print("========================")

# --- Eksekusi Program ---
item_price = 20000
item_quantity = 2

final_result = calculate_total_price(item_price, item_quantity)
display_invoice(item_price, item_quantity, final_result)
